{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "npm ci",
    "buildCommand": "npm run build",
    "outputDirectory": "public/build",
    "redirects": [
        {
            "source": "/:path*",
            "destination": "https://client-portal.up.railway.app/:path*",
            "permanent": false
        }
    ]
}
